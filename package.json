{
  "name": "fockeror",
  "version": "0.4.2",
  "description": "Типобезопасная фабрика ошибок с уникальными кодами, подстановкой плейсхолдеров и форматированием исключений, не зависящим от фреймворка.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FOCKUSTY/fockeror.git"
  },
  "homepage": "https://github.com/FOCKUSTY/fockeror#readme",
  "bugs": {
    "url": "https://github.com/FOCKUSTY/fockeror/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "error",
    "error-handling",
    "exceptions",
    "typescript",
    "errors-factory",
    "placeholders",
    "typed-errors",
    "http-errors",
    "error-codes",
    "validation",
    "logger"
  ],
  "author": {
    "name": "FOCKUSTY",
    "email": "viserd.yt@gmail.com",
    "url": "https://fockusty.vercel.app"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
